#!/usr/bin/env python3
"""
mem-fact category subject "content" -- upsert a fact into memory.db
Automatically generates and stores a Gemini embedding if API key is available.
Example: mem-fact people alice "frontend lead, loves Rust"
"""
import sys, os, json, sqlite3

# Resolve memlib from parent dir (bin/ is one level below memlib.py)
sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), ".."))
from memlib import embed, DB

def main():
    if len(sys.argv) < 4:
        print("Usage: mem-fact <category> <subject> <content>", file=sys.stderr)
        sys.exit(1)

    category, subject, content = sys.argv[1], sys.argv[2], " ".join(sys.argv[3:])

    conn = sqlite3.connect(DB)

    # Upsert the fact
    conn.execute("""
        INSERT INTO facts (category, subject, content, updated_at)
        VALUES (?, ?, ?, CURRENT_TIMESTAMP)
        ON CONFLICT(category, subject) DO UPDATE SET
            content = excluded.content,
            updated_at = CURRENT_TIMESTAMP
    """, (category, subject, content))
    conn.commit()

    # Get the fact_id
    row = conn.execute(
        "SELECT id FROM facts WHERE category=? AND subject=?", (category, subject)
    ).fetchone()
    fact_id = row[0]

    # Generate and store embedding (silently skip if unavailable)
    vector = embed(f"{category} {subject}: {content}")
    if vector:
        conn.execute("""
            INSERT INTO embeddings (fact_id, vector)
            VALUES (?, ?)
            ON CONFLICT(fact_id) DO UPDATE SET
                vector = excluded.vector,
                created_at = CURRENT_TIMESTAMP
        """, (fact_id, json.dumps(vector)))
        conn.commit()
        print(f"✓ fact saved + embedded: {category} / {subject}")
    else:
        print(f"✓ fact saved: {category} / {subject}")

    conn.close()

if __name__ == "__main__":
    main()
