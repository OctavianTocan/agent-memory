#!/usr/bin/env bash
# UserPromptSubmit hook -- regex extraction + memory context injection
# Fires before every agent message. Works with Claude Code, Cline, Gemini CLI, etc.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"
DATA_DIR="${AGENT_MEMORY_DIR:-$HOME/.agent-memory}"
DB="$DATA_DIR/memory.db"

# Tier 1 categories: full content injection
TIER1_CATEGORIES="'user_info','preferences'"

# Read the JSON payload from stdin (contains the user's prompt)
stdin_content=$(cat 2>/dev/null)

# Run regex extraction on the prompt, save any matched facts to DB
if [[ -n "$stdin_content" ]]; then
    echo "$stdin_content" | python3 "$SCRIPT_DIR/mem-extract" 2>/dev/null
fi

# Exit silently if DB doesn't exist
[[ ! -f "$DB" ]] && exit 0

# Check if any data exists
has_facts=$(sqlite3 "$DB" "SELECT COUNT(*) FROM facts;" 2>/dev/null)
has_soul=$(sqlite3 "$DB" "SELECT COUNT(*) FROM soul;" 2>/dev/null)
today=$(date +%Y-%m-%d)
has_logs=$(sqlite3 "$DB" "SELECT COUNT(*) FROM daily_logs WHERE date='$today';" 2>/dev/null)

# Exit silently if nothing to show
[[ "$has_facts" == "0" && "$has_soul" == "0" && "$has_logs" == "0" ]] && exit 0

datetime=$(date "+%a %d %b %Y, %H:%M")

echo "=== MEMORY CONTEXT [$datetime] ==="

# SOUL: always full content
if [[ "$has_soul" != "0" ]]; then
    echo ""
    echo "SOUL:"
    sqlite3 "$DB" "SELECT aspect || ': ' || content FROM soul ORDER BY aspect;" 2>/dev/null
fi

# USER: user_info category, full content
has_user=$(sqlite3 "$DB" "SELECT COUNT(*) FROM facts WHERE category='user_info';" 2>/dev/null)
if [[ "$has_user" != "0" ]]; then
    echo ""
    echo "USER:"
    sqlite3 "$DB" "SELECT subject || ': ' || content FROM facts WHERE category='user_info' ORDER BY subject;" 2>/dev/null
fi

# PREFERENCES: preferences category, full content
has_prefs=$(sqlite3 "$DB" "SELECT COUNT(*) FROM facts WHERE category='preferences';" 2>/dev/null)
if [[ "$has_prefs" != "0" ]]; then
    echo ""
    echo "PREFERENCES:"
    sqlite3 "$DB" "SELECT subject || ': ' || content FROM facts WHERE category='preferences' ORDER BY subject;" 2>/dev/null
fi

# TODAY'S LOG
if [[ "$has_logs" != "0" ]]; then
    echo ""
    echo "TODAY'S LOG:"
    sqlite3 "$DB" "SELECT '- [' || strftime('%H:%M', created_at, 'localtime') || '] ' || content FROM daily_logs WHERE date='$today' ORDER BY created_at;" 2>/dev/null
fi

# INDEX: all other facts (tier 2), description or truncated content
has_index=$(sqlite3 "$DB" "SELECT COUNT(*) FROM facts WHERE category NOT IN ($TIER1_CATEGORIES);" 2>/dev/null)
if [[ "$has_index" != "0" ]]; then
    echo ""
    echo "INDEX (use \`mem query \"SELECT content FROM facts WHERE category='x' AND subject='y'\"\` to fetch details):"
    sqlite3 "$DB" "SELECT category || '/' || subject || ': ' || COALESCE(description, REPLACE(SUBSTR(content, 1, 80), CHAR(10), ' ')) FROM facts WHERE category NOT IN ($TIER1_CATEGORIES) ORDER BY category, subject;" 2>/dev/null
fi

echo ""
echo "=== END MEMORY CONTEXT ==="
