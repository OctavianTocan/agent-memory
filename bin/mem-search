#!/usr/bin/env python3
"""
Semantic search across facts in memory.db using Gemini embeddings.
Usage: mem-search "natural language query"
Falls back to keyword search if no embeddings are stored or API unavailable.
"""
import sys, json, os, math, sqlite3
sys.path.insert(0, os.path.expanduser("~/.claude/projects/-Volumes-Crucial-X10-assistant/memory"))
from memlib import embed, DB

THRESHOLD = 0.3
TOP_N = 5

def cosine_sim(a, b):
    dot = sum(x * y for x, y in zip(a, b))
    mag_a = math.sqrt(sum(x * x for x in a))
    mag_b = math.sqrt(sum(x * x for x in b))
    return dot / (mag_a * mag_b) if mag_a and mag_b else 0.0

def semantic_search(query, conn):
    query_vec = embed(query)
    if query_vec is None:
        return None  # signal to fall back to keyword

    rows = conn.execute("""
        SELECT f.category, f.subject, f.content, e.vector
        FROM facts f
        JOIN embeddings e ON e.fact_id = f.id
    """).fetchall()

    if not rows:
        return None  # no embeddings stored yet

    scored = []
    for category, subject, content, vector_json in rows:
        stored_vec = json.loads(vector_json)
        score = cosine_sim(query_vec, stored_vec)
        if score >= THRESHOLD:
            scored.append((score, category, subject, content))

    scored.sort(reverse=True)
    return scored[:TOP_N]

def keyword_search(query, conn):
    terms = query.lower().split()
    rows = conn.execute("SELECT category, subject, content FROM facts").fetchall()
    results = []
    for category, subject, content in rows:
        haystack = f"{category} {subject} {content}".lower()
        if any(t in haystack for t in terms):
            results.append((category, subject, content))
    return results

def main():
    query = " ".join(sys.argv[1:])
    if not query:
        print("Usage: mem-search <query>", file=sys.stderr)
        sys.exit(1)

    if not os.path.exists(DB):
        print("No memory.db found", file=sys.stderr)
        sys.exit(1)

    conn = sqlite3.connect(DB)
    results = semantic_search(query, conn)

    if results is None:
        print("(no embeddings — using keyword search)\n")
        kw = keyword_search(query, conn)
        if not kw:
            print("No results found.")
        else:
            for category, subject, content in kw:
                print(f"  {category} / {subject}: {content}")
    elif not results:
        print("No results above similarity threshold.")
    else:
        print(f'Top results for: "{query}"\n')
        for score, category, subject, content in results:
            print(f"  [{score:.2f}] {category} / {subject}: {content}")

    conn.close()

if __name__ == "__main__":
    main()
