#!/usr/bin/env python3
"""
Generate a Gemini embedding for a piece of text.
Usage: mem-embed "text to embed"
Output: JSON array of floats, or exits with code 1 if unavailable.
"""
import sys, os, json

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), ".."))
from memlib import embed

if __name__ == "__main__":
    text = " ".join(sys.argv[1:])
    if not text:
        print("Usage: mem-embed <text>", file=sys.stderr)
        sys.exit(1)
    vector = embed(text)
    if vector is None:
        print("Error: could not generate embedding (check GEMINI_API_KEY)", file=sys.stderr)
        sys.exit(1)
    print(json.dumps(vector))
