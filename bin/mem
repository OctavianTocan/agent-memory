#!/usr/bin/env python3
"""
mem -- unified CLI for agent-memory

Usage:
    mem fact <category> <subject> <content> [--desc <description>]  Save a structured fact + auto-embed
    mem soul <aspect> <content>                                     Save an interaction preference
    mem log <note>                                                  Append to today's session log
    mem search <query>                                              Semantic search (keyword fallback)
    mem query <sql>                                                 Raw SQLite query
    mem embed <text>                                                Generate an embedding vector
    mem init                                                        Initialize the database schema
    mem status                                                      Show database stats
    mem export                                                      Export all data as JSON (lightweight)
    mem dump [file]                                                 Full database dump to JSON file
    mem import [file] [--force]                                     Import data from a dump file
    mem reset                                                       Wipe the database (with confirmation)
    mem update                                                      Pull latest code + re-install
    mem help                                                        Show this help
"""
import sys, os, json, sqlite3, math, subprocess
from datetime import date, datetime, timezone

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), ".."))
from memlib import embed as do_embed, DB, DATA_DIR

def get_conn():
    return sqlite3.connect(DB)

# -- subcommands --

def cmd_fact(args):
    """
    Save a structured fact with optional description.

    Args are parsed for --desc flag first. If found, the next element is
    the description value, and both are removed from args. The remainder
    is parsed as: category, subject, content (content is joined from all
    remaining args).

    The description is a short one-liner (under 80 chars) used by the
    context hook for compact index display.
    """
    # Parse --desc flag before validating args length
    desc = None
    if "--desc" in args:
        idx = args.index("--desc")
        if idx + 1 < len(args):
            desc = args[idx + 1]
            # Remove --desc and its value from args
            args = args[:idx] + args[idx + 2:]
        else:
            print("Error: --desc flag requires a value", file=sys.stderr)
            sys.exit(1)

    if len(args) < 3:
        print("Usage: mem fact <category> <subject> <content> [--desc <description>]", file=sys.stderr)
        sys.exit(1)

    category, subject, content = args[0], args[1], " ".join(args[2:])
    conn = get_conn()
    conn.execute("""
        INSERT INTO facts (category, subject, content, description, updated_at)
        VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP)
        ON CONFLICT(category, subject) DO UPDATE SET
            content = excluded.content,
            description = excluded.description,
            updated_at = CURRENT_TIMESTAMP
    """, (category, subject, content, desc))
    conn.commit()
    row = conn.execute("SELECT id FROM facts WHERE category=? AND subject=?", (category, subject)).fetchone()
    vector = do_embed(f"{category} {subject}: {content}")
    if vector:
        conn.execute("""
            INSERT INTO embeddings (fact_id, vector) VALUES (?, ?)
            ON CONFLICT(fact_id) DO UPDATE SET vector = excluded.vector, created_at = CURRENT_TIMESTAMP
        """, (row[0], json.dumps(vector)))
        conn.commit()
        print(f"✓ fact saved + embedded: {category} / {subject}")
    else:
        print(f"✓ fact saved: {category} / {subject}")
    conn.close()

def cmd_soul(args):
    if len(args) < 2:
        print("Usage: mem soul <aspect> <content>", file=sys.stderr)
        sys.exit(1)
    aspect, content = args[0], " ".join(args[1:])
    conn = get_conn()
    conn.execute("""
        INSERT INTO soul (aspect, content, updated_at) VALUES (?, ?, CURRENT_TIMESTAMP)
        ON CONFLICT(aspect) DO UPDATE SET content = excluded.content, updated_at = CURRENT_TIMESTAMP
    """, (aspect, content))
    conn.commit()
    conn.close()
    print(f"✓ soul saved: {aspect}")

def cmd_log(args):
    if not args:
        print("Usage: mem log <note>", file=sys.stderr)
        sys.exit(1)
    note = " ".join(args)
    conn = get_conn()
    conn.execute("INSERT INTO daily_logs (date, content) VALUES (?, ?)", (date.today().isoformat(), note))
    conn.commit()
    conn.close()
    print(f"✓ logged: {note}")

def cmd_search(args):
    if not args:
        print("Usage: mem search <query>", file=sys.stderr)
        sys.exit(1)
    query = " ".join(args)
    if not os.path.exists(DB):
        print("No memory.db found", file=sys.stderr)
        sys.exit(1)
    conn = get_conn()
    # Try semantic search first
    query_vec = do_embed(query)
    if query_vec:
        rows = conn.execute("""
            SELECT f.category, f.subject, f.content, e.vector
            FROM facts f JOIN embeddings e ON e.fact_id = f.id
        """).fetchall()
        if rows:
            scored = []
            for cat, subj, content, vec_json in rows:
                stored = json.loads(vec_json)
                dot = sum(a * b for a, b in zip(query_vec, stored))
                mag_a = math.sqrt(sum(x * x for x in query_vec))
                mag_b = math.sqrt(sum(x * x for x in stored))
                score = dot / (mag_a * mag_b) if mag_a and mag_b else 0.0
                if score >= 0.3:
                    scored.append((score, cat, subj, content))
            scored.sort(reverse=True)
            if scored:
                print(f'Top results for: "{query}"\n')
                for score, cat, subj, content in scored[:5]:
                    print(f"  [{score:.2f}] {cat} / {subj}: {content}")
                conn.close()
                return
    # Keyword fallback
    print("(keyword search)\n")
    terms = query.lower().split()
    rows = conn.execute("SELECT category, subject, content FROM facts").fetchall()
    results = [(c, s, t) for c, s, t in rows if any(term in f"{c} {s} {t}".lower() for term in terms)]
    if not results:
        print("No results found.")
    else:
        for cat, subj, content in results:
            print(f"  {cat} / {subj}: {content}")
    conn.close()

def cmd_query(args):
    if not args:
        print("Usage: mem query <sql>", file=sys.stderr)
        sys.exit(1)
    sql = " ".join(args)
    subprocess.run(["sqlite3", "-column", "-header", DB, sql])

def cmd_embed(args):
    if not args:
        print("Usage: mem embed <text>", file=sys.stderr)
        sys.exit(1)
    vector = do_embed(" ".join(args))
    if vector is None:
        print("Error: could not generate embedding (check GEMINI_API_KEY)", file=sys.stderr)
        sys.exit(1)
    print(json.dumps(vector))

def cmd_init(_args):
    os.makedirs(DATA_DIR, exist_ok=True)
    conn = sqlite3.connect(DB)
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS facts (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            category TEXT NOT NULL, subject TEXT NOT NULL, content TEXT NOT NULL,
            description TEXT,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            UNIQUE(category, subject)
        );
        CREATE TABLE IF NOT EXISTS soul (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            aspect TEXT NOT NULL UNIQUE, content TEXT NOT NULL,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
        );
        CREATE TABLE IF NOT EXISTS daily_logs (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            date TEXT NOT NULL, content TEXT NOT NULL,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP
        );
        CREATE TABLE IF NOT EXISTS embeddings (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            fact_id INTEGER NOT NULL UNIQUE, vector TEXT NOT NULL,
            model TEXT DEFAULT 'gemini-embedding-2-preview',
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (fact_id) REFERENCES facts(id) ON DELETE CASCADE
        );
    """)

    # Idempotent migration: add description column if it doesn't exist
    cursor = conn.execute("PRAGMA table_info(facts)")
    columns = [row[1] for row in cursor.fetchall()]
    if "description" not in columns:
        conn.execute("ALTER TABLE facts ADD COLUMN description TEXT")
        conn.commit()

    conn.close()
    print(f"✓ memory.db initialized at {DB}")

def cmd_status(_args):
    if not os.path.exists(DB):
        print("No memory.db found. Run: mem init")
        return
    conn = get_conn()
    facts = conn.execute("SELECT COUNT(*) FROM facts").fetchone()[0]
    soul = conn.execute("SELECT COUNT(*) FROM soul").fetchone()[0]
    embeds = conn.execute("SELECT COUNT(*) FROM embeddings").fetchone()[0]
    today = date.today().isoformat()
    logs = conn.execute("SELECT COUNT(*) FROM daily_logs WHERE date=?", (today,)).fetchone()[0]
    total_logs = conn.execute("SELECT COUNT(*) FROM daily_logs").fetchone()[0]
    size = os.path.getsize(DB)
    conn.close()
    print(f"agent-memory status")
    print(f"  db:         {DB} ({size / 1024:.0f} KB)")
    print(f"  facts:      {facts} ({embeds} with embeddings)")
    print(f"  soul:       {soul} aspects")
    print(f"  logs today: {logs} (total: {total_logs})")

def cmd_export(_args):
    if not os.path.exists(DB):
        print("No memory.db found.", file=sys.stderr)
        sys.exit(1)
    conn = get_conn()
    data = {
        "facts": [dict(zip(["category", "subject", "content"], r))
                  for r in conn.execute("SELECT category, subject, content FROM facts ORDER BY category, subject").fetchall()],
        "soul": [dict(zip(["aspect", "content"], r))
                 for r in conn.execute("SELECT aspect, content FROM soul ORDER BY aspect").fetchall()],
        "logs": [dict(zip(["date", "content", "created_at"], r))
                 for r in conn.execute("SELECT date, content, created_at FROM daily_logs ORDER BY created_at").fetchall()],
    }
    conn.close()
    print(json.dumps(data, indent=2))

def cmd_dump(args):
    if not os.path.exists(DB):
        print("No memory.db found.", file=sys.stderr)
        sys.exit(1)
    out_path = args[0] if args else os.path.join(DATA_DIR, "memory-dump.json")
    conn = get_conn()
    data = {
        "version": "1.0",
        "exported_at": datetime.now(timezone.utc).isoformat(),
        "tables": {
            "facts": [
                dict(zip(["id", "category", "subject", "content", "created_at", "updated_at"], r))
                for r in conn.execute(
                    "SELECT id, category, subject, content, created_at, updated_at FROM facts ORDER BY id"
                ).fetchall()
            ],
            "soul": [
                dict(zip(["id", "aspect", "content", "created_at", "updated_at"], r))
                for r in conn.execute(
                    "SELECT id, aspect, content, created_at, updated_at FROM soul ORDER BY id"
                ).fetchall()
            ],
            "daily_logs": [
                dict(zip(["id", "date", "content", "created_at"], r))
                for r in conn.execute(
                    "SELECT id, date, content, created_at FROM daily_logs ORDER BY id"
                ).fetchall()
            ],
            "embeddings": [
                dict(zip(["id", "fact_id", "vector", "model", "created_at"], r))
                for r in conn.execute(
                    "SELECT id, fact_id, vector, model, created_at FROM embeddings ORDER BY id"
                ).fetchall()
            ],
        },
    }
    conn.close()
    os.makedirs(os.path.dirname(os.path.abspath(out_path)), exist_ok=True)
    with open(out_path, "w") as f:
        json.dump(data, f, indent=2)
    total = sum(len(rows) for rows in data["tables"].values())
    print(f"✓ Dumped {total} rows to {out_path}")

def cmd_import(args):
    force = "--force" in args
    file_args = [a for a in args if a != "--force"]
    in_path = file_args[0] if file_args else os.path.join(DATA_DIR, "memory-dump.json")
    if not os.path.exists(in_path):
        print(f"File not found: {in_path}", file=sys.stderr)
        sys.exit(1)
    with open(in_path) as f:
        data = json.load(f)
    # Validate structure
    if "tables" not in data:
        print("Invalid dump file: missing 'tables' key.", file=sys.stderr)
        sys.exit(1)
    tables = data["tables"]
    expected = {"facts", "soul", "daily_logs", "embeddings"}
    missing = expected - set(tables.keys())
    if missing:
        print(f"Invalid dump file: missing tables {missing}.", file=sys.stderr)
        sys.exit(1)
    # Ensure DB exists
    if not os.path.exists(DB):
        cmd_init([])
    conn = get_conn()
    conn.execute("PRAGMA foreign_keys = OFF")
    counts = {}
    try:
        if force:
            for tbl in ["embeddings", "daily_logs", "soul", "facts"]:
                conn.execute(f"DELETE FROM {tbl}")
            conn.commit()
        # Import facts
        c = 0
        for row in tables.get("facts", []):
            conn.execute(
                "INSERT OR REPLACE INTO facts (id, category, subject, content, created_at, updated_at) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                (row["id"], row["category"], row["subject"], row["content"],
                 row.get("created_at"), row.get("updated_at")),
            )
            c += 1
        counts["facts"] = c
        # Import soul
        c = 0
        for row in tables.get("soul", []):
            conn.execute(
                "INSERT OR REPLACE INTO soul (id, aspect, content, created_at, updated_at) "
                "VALUES (?, ?, ?, ?, ?)",
                (row["id"], row["aspect"], row["content"],
                 row.get("created_at"), row.get("updated_at")),
            )
            c += 1
        counts["soul"] = c
        # Import daily_logs
        c = 0
        for row in tables.get("daily_logs", []):
            conn.execute(
                "INSERT OR REPLACE INTO daily_logs (id, date, content, created_at) "
                "VALUES (?, ?, ?, ?)",
                (row["id"], row["date"], row["content"], row.get("created_at")),
            )
            c += 1
        counts["daily_logs"] = c
        # Import embeddings
        c = 0
        for row in tables.get("embeddings", []):
            conn.execute(
                "INSERT OR REPLACE INTO embeddings (id, fact_id, vector, model, created_at) "
                "VALUES (?, ?, ?, ?, ?)",
                (row["id"], row["fact_id"], row["vector"],
                 row.get("model", "unknown"), row.get("created_at")),
            )
            c += 1
        counts["embeddings"] = c
        conn.commit()
    except Exception as e:
        conn.rollback()
        print(f"Import failed: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        conn.close()
    total = sum(counts.values())
    print(f"✓ Imported {total} rows from {in_path}")
    for tbl, n in counts.items():
        print(f"  {tbl}: {n}")

def cmd_reset(_args):
    if not os.path.exists(DB):
        print("No memory.db found.")
        return
    confirm = input(f"This will delete all data in {DB}. Type 'yes' to confirm: ")
    if confirm.strip().lower() != "yes":
        print("Aborted.")
        return
    os.remove(DB)
    cmd_init([])
    print("✓ Database reset.")

def cmd_update(_args):
    # Find the repo directory (parent of bin/)
    repo_dir = os.path.join(os.path.dirname(os.path.realpath(__file__)), "..")
    print(f"Updating from {repo_dir}")
    subprocess.run(["git", "-C", repo_dir, "pull"])
    install = os.path.join(repo_dir, "install.sh")
    subprocess.run(["bash", install])

def cmd_help(_args):
    print(__doc__.strip())

COMMANDS = {
    "fact": cmd_fact,
    "soul": cmd_soul,
    "log": cmd_log,
    "search": cmd_search,
    "query": cmd_query,
    "embed": cmd_embed,
    "init": cmd_init,
    "status": cmd_status,
    "export": cmd_export,
    "dump": cmd_dump,
    "import": cmd_import,
    "reset": cmd_reset,
    "update": cmd_update,
    "help": cmd_help,
}

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        cmd_help([])
        sys.exit(0)
    cmd = sys.argv[1]
    if cmd not in COMMANDS:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print(f"Run 'mem help' for usage.", file=sys.stderr)
        sys.exit(1)
    COMMANDS[cmd](sys.argv[2:])

if __name__ == "__main__":
    main()
