#!/usr/bin/env python3
"""
mem-soul aspect "content" — upsert a soul aspect into memory.db
Example: mem-soul communication_style "prefers direct answers without preamble"
"""
import sys, os, sqlite3
sys.path.insert(0, os.path.expanduser("~/.claude/projects/-Volumes-Crucial-X10-assistant/memory"))
from memlib import DB

def main():
    if len(sys.argv) < 3:
        print("Usage: mem-soul <aspect> <content>", file=sys.stderr)
        sys.exit(1)

    aspect = sys.argv[1]
    content = " ".join(sys.argv[2:])

    conn = sqlite3.connect(DB)
    conn.execute("""
        INSERT INTO soul (aspect, content, updated_at)
        VALUES (?, ?, CURRENT_TIMESTAMP)
        ON CONFLICT(aspect) DO UPDATE SET
            content = excluded.content,
            updated_at = CURRENT_TIMESTAMP
    """, (aspect, content))
    conn.commit()
    conn.close()
    print(f"✓ soul aspect saved: {aspect}")

if __name__ == "__main__":
    main()
