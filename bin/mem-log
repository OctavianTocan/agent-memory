#!/usr/bin/env python3
"""
mem-log "note" — append a timestamped note to today's log in memory.db
Example: mem-log "merged PR 696 on web-app"
"""
import sys, os, sqlite3
from datetime import date
sys.path.insert(0, os.path.expanduser("~/.claude/projects/-Volumes-Crucial-X10-assistant/memory"))
from memlib import DB

def main():
    if len(sys.argv) < 2:
        print("Usage: mem-log <note>", file=sys.stderr)
        sys.exit(1)

    note = " ".join(sys.argv[1:])
    today = date.today().isoformat()

    conn = sqlite3.connect(DB)
    conn.execute("INSERT INTO daily_logs (date, content) VALUES (?, ?)", (today, note))
    conn.commit()
    conn.close()
    print(f"✓ logged: {note}")

if __name__ == "__main__":
    main()
